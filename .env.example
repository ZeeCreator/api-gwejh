# Server Configuration
PORT=3000
NODE_ENV=development

# Response Format (set to 'false' for plain JSON)
USE_ENCRYPTION=true

# Encryption Key (must be 32 characters for AES-256)
ENCRYPTION_KEY=your-secret-key-32-chars-long!!!

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# Proxy Configuration (optional)
PROXY_ENABLED=false
PROXY_HOST=
PROXY_PORT=
PROXY_USERNAME=
PROXY_PASSWORD=

# Scraper Configuration
REQUEST_TIMEOUT=30000
MAX_RETRIES=3
RETRY_DELAY=1000
